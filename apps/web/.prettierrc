{
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-organize-imports"],
  "semi": true,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "svelteIndentScriptAndStyle": true,
  "overrides": [{ "files": "*.svelte", "options": { "parser": "svelte" } }]
}
