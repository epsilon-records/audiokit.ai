# OpenAI API Key for documentation generation
OPENAI_API_KEY=your_openai_api_key_here

# Google Analytics Key for documentation site
GOOGLE_ANALYTICS_KEY=your_ga_key_here

# Documentation versioning
DOCS_VERSION=latest

# Optional: Override default model for documentation generation
OPENAI_MODEL=gpt-4-turbo-preview

# Optional: Documentation generation settings
DOC_MIN_LENGTH=1000
DOC_MAX_TOKENS=2000
DOC_TEMPERATURE=0.7

# Optional: Logging settings
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(levelname)s - %(message)s"

# Pinecone Configuration
PINECONE_API_KEY=your-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp

# OpenAI Configuration (for LlamaIndex)
OPENAI_API_KEY=your-openai-key-here

# Audio Processing
WHISPER_MODEL=base  # Options: tiny, base, small, medium, large
OPENL3_EMBEDDING_SIZE=512

# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json
GOOGLE_CLOUD_PROJECT=your-project-id

# For testing, we can mock these services
TESTING=true
MOCK_SERVICES=true 