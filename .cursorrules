Key Data Structures:

interface Release {
id: string;
title: string;
artist: string;
type: 'Single' | 'EP' | 'Album';
releaseDate: Date;
artwork: string;
tracks: Track[];
status: 'draft' | 'pending' | 'processing' | 'live' | 'rejected';
platforms: DistributionPlatform[];
}

interface Event {
id: string;
title: string;
type: 'concert' | 'festival' | 'meetup' | 'release_party';
date: Date;
venue: Venue;
ticketing: TicketingInfo;
capacity: number;
soldTickets: number;
status: 'draft' | 'published' | 'cancelled' | 'completed';
promotion: PromotionDetails;
}

interface TeamMember {
id: string;
role: TeamRole;
permissions: Permission[];
assignments: Task[];
activity: ActivityLog[];
}

interface Content {
id: string;
type: 'blog' | 'news' | 'release' | 'press';
title: string;
body: string;
author: string;
status: 'draft' | 'published' | 'archived';
publishDate: Date;
media: MediaAsset[];
seo: SEOMetadata;
analytics: ContentAnalytics;
}

