# AI Development Assistant Workflow
init:
    # Initialize and update submodules
    git submodule update --init --recursive
    echo "✅ Submodules initialized and updated"

commit-all:
    # Commit audiokit subdirectory changes
    cd audiokit && git add . && git commit -m "feat(ai): 🧠✨ Neural networks did the heavy lifting" || echo "⚠️ No changes in audiokit submodule"
    # Commit root project changes
    cd .. && git add . && git commit -m "chore(ai): 🤖⚡️ Automated code alchemy in progress" || echo "⚠️ No changes in root project"

sync:
    #!/usr/bin/env sh
    # Get current branch for root repo
    ROOT_BRANCH=`git branch --show-current`
    # Get current branch for submodule
    cd audiokit
    SUBMODULE_BRANCH=`git branch --show-current`
    cd ..
    
    # Sync root repository
    git pull --rebase origin $ROOT_BRANCH
    git push origin $ROOT_BRANCH
    
    # Sync submodule
    cd audiokit
    git pull --rebase origin $SUBMODULE_BRANCH
    git push origin $SUBMODULE_BRANCH
    cd ..
    
    echo "🌐 Changes synchronized across all repositories"

ai-workflow: init commit-all sync
    #!/usr/bin/env sh
    echo "🚀 AI development cycle complete! Matrix updated successfully!"
    if ! command -v xxd > /dev/null; then
        echo "Using Python fallback for binary conversion..."
        python3 -c 'print("Code ascended!")'
    else
        echo "436F646520617363656E64656421" | xxd -r -p || echo "Binary conversion failed"
    fi
    echo

status:
    # Check status of both main repo and submodule
    git status
    cd audiokit && git status
    cd ..
    echo "🔍 Repository status checked"